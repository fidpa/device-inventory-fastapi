# device-inventory-fastapi — Environment variables
# Copy this file to `.env` and fill in the values below.

# ──────────────────────────────────────────────────────────────────────────
# Nextcloud / WebDAV credentials
# Works with any WebDAV-compatible cloud (Nextcloud, ownCloud, Seafile, etc.)
# ──────────────────────────────────────────────────────────────────────────
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=sysinfo
NEXTCLOUD_PASSWORD=<APP_PASSWORD>

# WebDAV path relative to the user root
NEXTCLOUD_PATH=/remote.php/dav/files/sysinfo/inbox

# ──────────────────────────────────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────────────────────────────────
# Generate the bcrypt hash:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt(12)).decode())"
AUTH_PASSWORD_HASH=<BCRYPT_HASH>

# Generate the HMAC secret (32+ bytes recommended):
#   python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_SECRET=<RANDOM_HEX_64>
