[Unit]
Description=Device Inventory — Nextcloud Import (Oneshot)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=device-inventory
WorkingDirectory=/opt/device-inventory
ExecStart=/opt/device-inventory/venv/bin/python3 /opt/device-inventory/scripts/import_sysinfo.py
TimeoutStartSec=180
StandardOutput=journal
StandardError=journal
